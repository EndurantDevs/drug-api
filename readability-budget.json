{
  "version": 1,
  "source_roots": [
    "main.py",
    "api",
    "db",
    "process",
    "scripts",
    "tests"
  ],
  "include_suffixes": [
    ".py"
  ],
  "exclude_globs": [
    ".git/**",
    ".venv/**",
    "venv/**",
    "venv313/**",
    "venv_old_20260321/**",
    "env/**",
    ".pytest_cache/**",
    ".mypy_cache/**",
    ".ruff_cache/**",
    ".tox/**",
    ".nox/**",
    "**/__pycache__/**",
    "build/**",
    "dist/**",
    "htmlcov/**",
    "reports/**",
    "tmp/**",
    "docs/_build/**",
    "site/**",
    "service/**"
  ],
  "thresholds": {
    "max_file_lines": 500,
    "max_function_lines": 60,
    "max_nesting_depth": 4
  },
  "inline_suppression_patterns": [
    {
      "name": "python_noqa",
      "pattern": "#\\s*noqa\\b"
    },
    {
      "name": "python_type_ignore",
      "pattern": "#\\s*type:\\s*ignore\\b"
    },
    {
      "name": "python_pylint_disable",
      "pattern": "#\\s*pylint:\\s*disable\\b"
    },
    {
      "name": "javascript_eslint_disable",
      "pattern": "eslint-disable"
    },
    {
      "name": "typescript_ts_ignore",
      "pattern": "@ts-ignore"
    },
    {
      "name": "typescript_ts_expect_error",
      "pattern": "@ts-expect-error"
    },
    {
      "name": "rust_allow",
      "pattern": "#\\[allow\\("
    }
  ]
}
